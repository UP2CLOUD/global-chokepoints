# ============================================================
# IsHormuzOpen — environment variables
# Copy this file to .env.local and fill in the keys you have.
# Every key is OPTIONAL: the dashboard degrades gracefully without them.
# ============================================================

# --- Markets (Brent + WTI) ------------------------------------
# EIA Open Data — official US government oil prices.
# Register (free, 30 seconds):  https://www.eia.gov/opendata/register.php
# When set, /api/brent and /api/markets use EIA as the primary source
# and fall back to Yahoo Finance if EIA is unreachable.
EIA_API_KEY=

# --- Maritime (AIS positions) ---------------------------------
# AISStream.io — free WebSocket AIS feed.
# Register:  https://aisstream.io/authenticate
# After registering, paste the key here.
# The collector script (npm run ais) maintains the WebSocket and
# writes data/vessels.json that /api/vessels reads.
AISSTREAM_KEY=

# --- Optional: paid news upgrades -----------------------------
# NewsAPI.org — 100 req/day free tier.  https://newsapi.org/register
NEWS_API_KEY=

# Alpha Vantage — fallback for markets if EIA + Yahoo both fail.
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=
