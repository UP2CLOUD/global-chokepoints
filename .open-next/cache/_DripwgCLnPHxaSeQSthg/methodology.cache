[#E6ECF3]\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-3xl mx-auto px-5 md:px-8 py-10 md:py-14\",\"children\":[[\"$\",\"$L4\",null,{\"href\":\"/\",\"className\":\"text-[11px] font-mono uppercase tracking-[0.18em] text-[#06B6D4] hover:underline\",\"children\":\"← Back to dashboard\"}],[\"$\",\"h1\",null,{\"className\":\"mt-6 text-3xl md:text-4xl font-semibold tracking-tight\",\"children\":\"Methodology\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-[#A9B4C2] leading-relaxed\",\"children\":\"IsStraitHormuzOpen? is a public intelligence dashboard monitoring the operational state of the Strait of Hormuz. Every number on the page is computed from a documented source on a documented cadence. This page explains how.\"}],[\"$\",\"section\",null,{\"className\":\"mt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-semibold tracking-tight text-[#E6ECF3]\",\"children\":\"1. What we measure\"}],[\"$\",\"div\",null,{\"className\":\"mt-3 text-[#A9B4C2] leading-relaxed space-y-3 text-sm\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"The headline output is the \",[\"$\",\"strong\",null,{\"children\":\"Strait State\"}],\": one of\",\" \",[\"$\",\"code\",null,{\"children\":\"OPEN\"}],\", \",[\"$\",\"code\",null,{\"children\":\"DISRUPTED\"}],\", or \",[\"$\",\"code\",null,{\"children\":\"CLOSED\"}],\". It is derived in real time from the most recent 72 hours of news, weighted by severity, plus the day's Brent crude move.\"]}],[\"$\",\"p\",null,{\"children\":[\"Alongside the state we publish a \",[\"$\",\"strong\",null,{\"children\":\"Tension Level\"}],\" \",\"(NORMAL / ELEVATED / CRITICAL) and an \",[\"$\",\"strong\",null,{\"children\":\"analyst confidence\"}],\" score in [0, 1] that grows with source diversity and event density.\"]}]]}]]}],[\"$\",\"section\",null,{\"className\":\"mt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-semibold tracking-tight text-[#E6ECF3]\",\"children\":\"2. Sources\"}],[\"$\",\"div\",null,{\"className\":\"mt-3 text-[#A9B4C2] leading-relaxed space-y-3 text-sm\",\"children\":[\"$\",\"div\",null,{\"className\":\"overflow-x-auto\",\"children\":[\"$\",\"table\",null,{\"className\":\"w-full text-sm border border-[#1E2533] rounded-lg overflow-hidden\",\"children\":[[\"$\",\"thead\",null,{\"className\":\"bg-[#0B0F18] text-[#6B7787] text-[11px] uppercase tracking-wider\",\"children\":[\"$\",\"tr\",null,{\"children\":[[\"$\",\"th\",null,{\"className\":\"text-left px-3 py-2\",\"children\":\"Source\"}],[\"$\",\"th\",null,{\"className\":\"text-left px-3 py-2\",\"children\":\"Used for\"}],[\"$\",\"th\",null,{\"className\":\"text-left px-3 py-2\",\"children\":\"Refresh\"}],[\"$\",\"th\",null,{\"className\":\"text-left px-3 py-2\",\"children\":\"License / notes\"}]]}]}],[\"$\",\"tbody\",null,{\"children\":[[\"$\",\"tr\",\"Yahoo Finance\",{\"className\":\"border-t border-[#1E2533]\",\"children\":[[\"$\",\"td\",null,{\"className\":\"px-3 py-2 font-medium\",\"children\":\"Yahoo Finance\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#A9B4C2]\",\"children\":\"Brent crude (BZ=F), WTI (CL=F), Henry Hub (NG=F)\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#A9B4C2] font-mono\",\"children\":\"5 min\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#6B7787]\",\"children\":\"Public unofficial endpoint; replace with EIA/ICE for production.\"}]]}],[\"$\",\"tr\",\"GDELT v2 Doc API\",{\"className\":\"border-t border-[#1E2533]\",\"children\":[[\"$\",\"td\",null,{\"className\":\"px-3 py-2 font-medium\",\"children\":\"GDELT v2 Doc API\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#A9B4C2]\",\"children\":\"Global news article discovery\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#A9B4C2] font-mono\",\"children\":\"5 min\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#6B7787]\",\"children\":\"Free; attribution requested.\"}]]}],[\"$\",\"tr\",\"CNN RSS\",{\"className\":\"border-t border-[#1E2533]\",\"children\":[[\"$\",\"td\",null,{\"className\":\"px-3 py-2 font-medium\",\"children\":\"CNN RSS\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#A9B4C2]\",\"children\":\"World + Middle East headlines\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#A9B4C2] font-mono\",\"children\":\"60 s\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#6B7787]\",\"children\":\"Public RSS; headlines + links only.\"}]]}],[\"$\",\"tr\",\"BBC RSS\",{\"className\":\"border-t border-[#1E2533]\",\"children\":[[\"$\",\"td\",null,{\"className\":\"px-3 py-2 font-medium\",\"children\":\"BBC RSS\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#A9B4C2]\",\"children\":\"World + Middle East headlines\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#A9B4C2] font-mono\",\"children\":\"60 s\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#6B7787]\",\"children\":\"Public RSS; headlines + links only.\"}]]}],[\"$\",\"tr\",\"Al Jazeera RSS\",{\"className\":\"border-t border-[#1E2533]\",\"children\":[[\"$\",\"td\",null,{\"className\":\"px-3 py-2 font-medium\",\"children\":\"Al Jazeera RSS\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#A9B4C2]\",\"children\":\"Headlines + summaries\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#A9B4C2] font-mono\",\"children\":\"60 s\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#6B7787]\",\"children\":\"Public RSS.\"}]]}],[\"$\",\"tr\",\"Reuters (via Google News mirror)\",{\"className\":\"border-t border-[#1E2533]\",\"children\":[[\"$\",\"td\",null,{\"className\":\"px-3 py-2 font-medium\",\"children\":\"Reuters (via Google News mirror)\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#A9B4C2]\",\"children\":\"Headlines + links\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#A9B4C2] font-mono\",\"children\":\"60 s\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#6B7787]\",\"children\":\"Reuters direct RSS is paid; mirror is fair-use headline aggregation.\"}]]}],[\"$\",\"tr\",\"Open-Meteo\",{\"className\":\"border-t border-[#1E2533]\",\"children\":[[\"$\",\"td\",null,{\"className\":\"px-3 py-2 font-medium\",\"children\":\"Open-Meteo\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#A9B4C2]\",\"children\":\"Wind, visibility, wave height at 26.5°N 56.4°E\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#A9B4C2] font-mono\",\"children\":\"15 min\"}],[\"$\",\"td\",null,{\"className\":\"px-3 py-2 text-[#6B7787]\",\"children\":\"CC-BY-4.0; no key required.\"}]]}]]}]]}]}]}]]}],[\"$\",\"section\",null,{\"className\":\"mt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-semibold tracking-tight text-[#E6ECF3]\",\"children\":\"3. How status is computed\"}],[\"$\",\"div\",null,{\"className\":\"mt-3 text-[#A9B4C2] leading-relaxed space-y-3 text-sm\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"The function lives in \",[\"$\",\"code\",null,{\"children\":\"app/lib/api.ts\"}],\" as\",\" \",[\"$\",\"code\",null,{\"children\":\"deriveStatus()\"}],\". Pseudocode:\"]}],[\"$\",\"pre\",null,{\"className\":\"mt-3 p-4 bg-[#0B0F18] border border-[#1E2533] rounded-lg text-[12px] overflow-x-auto leading-relaxed\",\"children\":\"recent  = events in past 72h\\nlast24  = events in past 24h\\n\\n# State\\nif recent matches /closed|closure|blocked|suspended|halted/  -> CLOSED\\nelif recent matches /diverted|rerouted|delayed|evacuated/    -> DISRUPTED\\nelse                                                          -> OPEN\\n\\n# Tension\\nweight = { low: 1, medium: 2, high: 4, critical: 7 }\\nscore  = sum(weight[e.severity] for e in last24)\\nif |brent_change_pct| >= 3:  score += 4\\nif score >= 14 or state != OPEN: tensionLevel = CRITICAL\\nelif score >= 5:                  tensionLevel = ELEVATED\\nelse:                              tensionLevel = NORMAL\\n\\n# Confidence\\nsources    = unique(e.source for e in last24)\\nconfidence = min(0.99, 0.55 + 0.06 * |sources| + 0.02 * min(|last24|, 6))\"}]]}]]}],[\"$\",\"section\",null,{\"className\":\"mt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-semibold tracking-tight text-[#E6ECF3]\",\"children\":\"4. Refresh cadence\"}],[\"$\",\"div\",null,{\"className\":\"mt-3 text-[#A9B4C2] leading-relaxed space-y-3 text-sm\",\"children\":[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-1 text-[#A9B4C2]\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"Timeline / RSS aggregator — \",[\"$\",\"strong\",null,{\"children\":\"every 60 seconds\"}]]}],[\"$\",\"li\",null,{\"children\":\"News (GDELT) — every 5 minutes\"}],[\"$\",\"li\",null,{\"children\":\"Brent / WTI / Henry Hub — every 5 minutes\"}],[\"$\",\"li\",null,{\"children\":\"Weather (Open-Meteo) — every 15 minutes\"}],[\"$\",\"li\",null,{\"children\":\"Feed health — every 30 seconds\"}]]}]}]]}],[\"$\",\"section\",null,{\"className\":\"mt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-semibold tracking-tight text-[#E6ECF3]\",\"children\":\"5. Public API\"}],[\"$\",\"div\",null,{\"className\":\"mt-3 text-[#A9B4C2] leading-relaxed space-y-3 text-sm\",\"children\":[[\"$\",\"p\",null,{\"children\":\"A read-only JSON API is available for embeds and partner sites. CORS is allow-all and responses are cached at the edge.\"}],[\"$\",\"pre\",null,{\"className\":\"mt-3 p-4 bg-[#0B0F18] border border-[#1E2533] rounded-lg text-[12px] overflow-x-auto leading-relaxed\",\"children\":\"GET /v1/status              # headline state, tension, confidence\\nGET /v1/events?limit=30     # latest aggregated events\\nGET /v1/events?since=ISO    # incremental fetch\\nGET /v1/metrics             # markets, weather, event counts\\nGET /feed.xml               # RSS 2.0 for journalists\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-[#6B7787] text-sm\",\"children\":\"License: CC-BY-4.0. Attribution required as “IsStraitHormuzOpen?” with a link back.\"}]]}]]}],[\"$\",\"section\",null,{\"className\":\"mt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-semibold tracking-tight text-[#E6ECF3]\",\"children\":\"6. Known limitations\"}],[\"$\",\"div\",null,{\"className\":\"mt-3 text-[#A9B4C2] leading-relaxed space-y-3 text-sm\",\"children\":[\"$\",\"ul\",null,{\"className\":\"list-disc list-inside space-y-1 text-[#A9B4C2]\",\"children\":[[\"$\",\"li\",null,{\"children\":\"Real-time AIS (vessel positions) requires a paid feed; the map currently uses a simulated shipping-lane animation and is explicitly labelled as such.\"}],[\"$\",\"li\",null,{\"children\":\"Sentiment is a keyword-matching heuristic. It can mislabel ironic or quoted headlines. Treat as a directional signal, not an editorial judgement.\"}],[\"$\",\"li\",null,{\"children\":\"RSS deduplication is URL-based; near-duplicate stories from different outlets may still appear separately.\"}],[\"$\",\"li\",null,{\"children\":\"Yahoo Finance is an unofficial endpoint and may rate-limit during very high traffic. EIA / ICE replacement is on the V2 roadmap.\"}]]}]}]]}],[\"$\",\"section\",null,{\"className\":\"mt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-semibold tracking-tight text-[#E6ECF3]\",\"children\":\"7. Change log\"}],[\"$\",\"div\",null,{\"className\":\"mt-3 text-[#A9B4C2] leading-relaxed space-y-3 text-sm\",\"children\":[\"$\",\"ul\",null,{\"className\":\"space-y-2\",\"children\":[[\"$\",\"li\",\"0.2.0\",{\"className\":\"border-l-2 border-[#06B6D4]/50 pl-3\",\"children\":[[\"$\",\"div\",null,{\"className\":\"text-[11px] text-[#06B6D4] font-mono\",\"children\":[\"v\",\"0.2.0\",\" · \",\"2026-05-12\"]}],[\"$\",\"div\",null,{\"className\":\"text-[#A9B4C2] text-sm\",\"children\":\"Live data architecture: API routes, RSS aggregator, status derivation, public /v1 API, RSS feed, methodology page.\"}]]}],[\"$\",\"li\",\"0.1.0\",{\"className\":\"border-l-2 border-[#06B6D4]/50 pl-3\",\"children\":[[\"$\",\"div\",null,{\"className\":\"text-[11px] text-[#06B6D4] font-mono\",\"children\":[\"v\",\"0.1.0\",\" · \",\"2026-05-11\"]}],[\"$\",\"div\",null,{\"className\":\"text-[#A9B4C2] text-sm\",\"children\":\"Initial Next.js port of the static dashboard; visual + i18n only.\"}]]}]]}]}]]}],[\"$\",\"section\",null,{\"className\":\"mt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-semibold tracking-tight text-[#E6ECF3]\",\"children\":\"8. Disclaimer\"}],[\"$\",\"div\",null,{\"className\":\"mt-3 text-[#A9B4C2] leading-relaxed space-y-3 text-sm\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-[#A9B4C2]\",\"children\":[\"This site provides information for situational awareness only. It is \",[\"$\",\"strong\",null,{\"children\":\"not\"}],\" navigational, financial, military or operational advice. Always verify with official authorities (IMO, NAVCENT, UKMTO, port authorities, your insurer's war-risk cell) before making decisions. Predictions are probabilistic and do not represent a forecast of imminent events.\"]}]}]]}],[\"$\",\"section\",null,{\"className\":\"mt-10\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-semibold tracking-tight text-[#E6ECF3]\",\"children\":\"9. Contact\"}],[\"$\",\"div\",null,{\"className\":\"mt-3 text-[#A9B4C2] leading-relaxed space-y-3 text-sm\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-[#A9B4C2]\",\"children\":[\"Corrections, source suggestions, takedowns, press enquiries:\",\" \",[\"$\",\"a\",null,{\"className\":\"text-[#06B6D4] hover:underline\",\"href\":\"mailto:contact@ishormuzopen.example\",\"children\":\"contact@ishormuzopen.example\"}]]}]}]]}],[\"$\",\"footer\",null,{\"className\":\"mt-12 pt-6 border-t border-[#1E2533] text-[11px] text-[#6B7787] font-mono\",\"children\":[\"© \",2026,\" IsStraitHormuzOpen? ·\",\" \",[\"$\",\"$L4\",null,{\"href\":\"/\",\"className\":\"hover:text-[#06B6D4]\",\"children\":\"Dashboard\"}],\" ·\",\" \",[\"$\",\"a\",null,{\"href\":\"/feed.xml\",\"className\":\"hover:text-[#06B6D4]\",\"children\":\"RSS\"}],\" ·\",\" \",[\"$\",\"a\",null,{\"href\":\"/v1/status\",\"className\":\"hover:text-[#06B6D4]\",\"children\":\"API\"}]]}]]}]}],[\"$\",\"$L5\"