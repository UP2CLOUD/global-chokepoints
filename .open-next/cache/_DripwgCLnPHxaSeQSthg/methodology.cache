                                         -\\u003e OPEN\\\\n\\\\n# Tension\\\\nweight = { low: 1, medium: 2, high: 4, critical: 7 }\\\\nscore  = sum(weight[e.severity] for e in last24)\\\\nif |brent_change_pct| \\u003e= 3:  score += 4\\\\nif score \\u003e= 14 or state != OPEN: tensionLevel = CRITICAL\\\\nelif score \\u003e= 5:                  tensionLevel = ELEVATED\\\\nelse:                              tensionLevel = NORMAL\\\\n\\\\n# Confidence\\\\nsources    = unique(e.source for e in last24)\\\\nconfidence = min(0.99, 0.55 + 0.06 * |sources| + 0.02 * min(|last24|, 6))\\\"}]]}]]}],[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"mt-10\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-lg font-semibold tracking-tight text-[#E6ECF3]\\\",\\\"children\\\":\\\"4. Refresh cadence\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-3 text-[#A9B4C2] leading-relaxed space-y-3 text-sm\\\",\\\"children\\\":[\\\"$\\\",\\\"ul\\\",null,{\\\"className\\\":\\\"list-disc list-inside space-y-1 text-[#A9B4C2]\\\",\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[\\\"Timeline / RSS aggregator — \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"every 60 seconds\\\"}]]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"News (GDELT) — every 5 minutes\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Brent / WTI / Henry Hub — every 5 minutes\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Weather (Open-Meteo) — every 15 minutes\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Feed health — every 30 seconds\\\"}]]}]}]]}],[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"mt-10\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-lg font-semibold tracking-tight text-[#E6ECF3]\\\",\\\"children\\\":\\\"5. Public API\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-3 text-[#A9B4C2] leading-relaxed space-y-3 text-sm\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"A read-only JSON API is available for embeds and partner sites. CORS is allow-all and responses are cached at the edge.\\\"}],[\\\"$\\\",\\\"pre\\\",null,{\\\"className\\\":\\\"mt-3 p-4 bg-[#0B0F18] border border-[#1E2533] rounded-lg text-[12px] overflow-x-auto leading-relaxed\\\",\\\"children\\\":\\\"GET /v1/status              # headline state, tension, confidence\\\\nGET /v1/events?limit=30     # latest aggregated events\\\\nGET /v1/events?since=ISO    # incremental fetch\\\\nGET /v1/metrics             # markets, weather, event counts\\\\nGET /feed.xml               # RSS 2.0 for journalists\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"mt-3 text-[#6B7787] text-sm\\\",\\\"children\\\":\\\"License: CC-BY-4.0. Attribution required as “IsStraitHormuzOpen?” with a link back.\\\"}]]}]]}],[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"mt-10\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-lg font-semibold tracking-tight text-[#E6ECF3]\\\",\\\"children\\\":\\\"6. Known limitations\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-3 text-[#A9B4C2] leading-relaxed space-y-3 text-sm\\\",\\\"children\\\":[\\\"$\\\",\\\"ul\\\",null,{\\\"className\\\":\\\"list-disc list-inside space-y-1 text-[#A9B4C2]\\\",\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Real-time AIS (vessel positions) requires a paid feed; the map currently uses a simulated shipping-lane animation and is explicitly labelled as such.\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Sentiment is a keyword-matching heuristic. It can mislabel ironic or quoted headlines. Treat as a directional signal, not an editorial judgement.\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"RSS deduplication is URL-based; near-duplicate stories from different outlets may still appear separately.\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Yahoo Finance is an unofficial endpoint and may rate-limit during very high traffic. EIA / ICE replacement is on the V2 roadmap.\\\"}]]}]}]]}],[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"mt-10\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-lg font-semibold tracking-tight text-[#E6ECF3]\\\",\\\"children\\\":\\\"7. Change log\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-3 text-[#A9B4C2] leading-relaxed space-y-3 text-sm\\\",\\\"children\\\":[\\\"$\\\",\\\"ul\\\",null,{\\\"className\\\":\\\"space-y-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"li\\\",\\\"0.2.0\\\",{\\\"className\\\":\\\"border-l-2 border-[#06B6D4]/50 pl-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-[11px] text-[#06B6D4] font-mono\\\",\\\"children\\\":[\\\"v\\\",\\\"0.2.0\\\",\\\" · \\\",\\\"2026-05-12\\\"]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-[#A9B4C2] text-sm\\\",\\\"children\\\":\\\"Live data architecture: API routes, RSS aggregator, status derivation, public /v1 API, RSS feed, methodology page.\\\"}]]}],[\\\"$\\\",\\\"li\\\",\\\"0.1.0\\\",{\\\"className\\\":\\\"border-l-2 border-[#06B6D4]/50 pl-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-[11px] text-[#06B6D4] font-mono\\\",\\\"children\\\":[\\\"v\\\",\\\"0.1.0\\\",\\\" · \\\",\\\"2026-05-11\\\"]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-[#A9B4C2] text-sm\\\",\\\"children\\\":\\\"Initial Next.js port of the static dashboard; visual + i18n only.\\\"}]]}]]}]}]]}],[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"mt-10\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-lg font-semibold tracking-tight text-[#E6ECF3]\\\",\\\"children\\\":\\\"8. Disclaimer\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-3 text-[#A9B4C2] leading-relaxed space-y-3 text-sm\\\",\\\"children\\\":[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-[#A9B4C2]\\\",\\\"children\\\":[\\\"This site provides information for situational awareness only. It is \\\",[\\\"$\