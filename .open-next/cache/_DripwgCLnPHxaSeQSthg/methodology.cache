"text-lg font-semibold tracking-tight text-[#E6ECF3]\\\",\\\"children\\\":\\\"1. What we measure\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-3 text-[#A9B4C2] leading-relaxed space-y-3 text-sm\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"The headline output is the \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Strait State\\\"}],\\\": one of\\\",\\\" \\\",[\\\"$\\\",\\\"code\\\",null,{\\\"children\\\":\\\"OPEN\\\"}],\\\", \\\",[\\\"$\\\",\\\"code\\\",null,{\\\"children\\\":\\\"DISRUPTED\\\"}],\\\", or \\\",[\\\"$\\\",\\\"code\\\",null,{\\\"children\\\":\\\"CLOSED\\\"}],\\\". It is derived in real time from the most recent 72 hours of news, weighted by severity, plus the day's Brent crude move.\\\"]}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"Alongside the state we publish a \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Tension Level\\\"}],\\\" \\\",\\\"(NORMAL / ELEVATED / CRITICAL) and an \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"analyst confidence\\\"}],\\\" score in [0, 1] that grows with source diversity and event density.\\\"]}]]}]]}],[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"mt-10\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-lg font-semibold tracking-tight text-[#E6ECF3]\\\",\\\"children\\\":\\\"2. Sources\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-3 text-[#A9B4C2] leading-relaxed space-y-3 text-sm\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"overflow-x-auto\\\",\\\"children\\\":[\\\"$\\\",\\\"table\\\",null,{\\\"className\\\":\\\"w-full text-sm border border-[#1E2533] rounded-lg overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"thead\\\",null,{\\\"className\\\":\\\"bg-[#0B0F18] text-[#6B7787] text-[11px] uppercase tracking-wider\\\",\\\"children\\\":[\\\"$\\\",\\\"tr\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"th\\\",null,{\\\"className\\\":\\\"text-left px-3 py-2\\\",\\\"children\\\"