{
  "name": "strait-of-hormuz-monitor",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "ais": "node scripts/ais-collector.mjs",
    "start:local": "bash scripts/run.sh",
    "build:cf": "npx @cloudflare/next-on-pages@1",
    "preview:cf": "npm run build:cf && wrangler pages dev .vercel/output/static --d1=DB",
    "db:migrate": "wrangler d1 execute strait-subscriptions --file=migrations/0001_subscriptions.sql",
    "db:migrate:local": "wrangler d1 execute strait-subscriptions --local --file=migrations/0001_subscriptions.sql",
    "deploy:cf": "npm run build:cf && wrangler pages deploy .vercel/output/static --project-name=strait-of-hormuz-monitor"
  },
  "dependencies": {
    "next": "14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0",
    "react-leaflet": "^4.2.1",
    "leaflet": "^1.9.4",
    "@tanstack/react-query": "^5.32.0",
    "zustand": "^4.5.0",
    "lucide-react": "^0.378.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.3.0",
    "date-fns": "^3.6.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.7",
    "wrangler": "^3.57.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/leaflet": "^1.9.0",
    "@types/ws": "^8.5.10",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.0"
  }
}
