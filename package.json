{
  "name": "global-chokepoints",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "ais": "node scripts/ais-collector.mjs",
    "start:local": "bash scripts/run.sh",
    "build:cf": "npx @cloudflare/next-on-pages && rm -rf .next",
    "preview:cf": "npm run build:cf && wrangler pages dev .vercel/output/static",
    "db:migrate": "wrangler d1 execute strait-subscriptions --remote --file=migrations/0001_subscriptions.sql",
    "db:migrate:local": "wrangler d1 execute strait-subscriptions --local --file=migrations/0001_subscriptions.sql",
    "deploy:cf": "npm run build:cf && wrangler pages deploy .vercel/output/static"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-query": "^5.101.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "esbuild": "^0.28.1",
    "gsap": "^3.15.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.378.0",
    "next": "^15.5.18",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-leaflet": "^4.2.1",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.3.0",
    "three": "^0.184.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/leaflet": "^1.9.0",
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.4.0",
    "wrangler": "^4.100.0"
  }
}
