# Strait of Hormuz Monitor - Environment Variables Example

# API Keys (Required for live data)
# AISSTREAM_KEY=your_key_here
# RESEND_API_KEY=your_key_here
# RESEND_FROM_EMAIL=alerts@yourdomain.com

# Cloudflare Turnstile (Anti-spam)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Monetization & Redesign Config
NEXT_PUBLIC_SUPPORT_URL=https://ko-fi.com/yourusername
NEXT_PUBLIC_SPONSOR_NAME=Buy me a Ko-fi
NEXT_PUBLIC_SPONSOR_URL=https://ko-fi.com/cesarnog
NEXT_PUBLIC_ADS_ENABLED=true
NEXT_PUBLIC_PREMIUM_ENABLED=true
NEXT_PUBLIC_API_ACCESS_URL=/api-access
NEXT_PUBLIC_NEWSLETTER_URL=
NEXT_PUBLIC_CONTACT_EMAIL=contact@ishormuzopen.example

# Deployment
NEXT_PUBLIC_SITE_URL=https://strait-of-hormuz-monitor.workers.dev
